# Copy to .env (gitignored) and fill in real values. Never commit the real file.

PORT=8080

# postgres://<user>:<password>@<host>:<port>/<dbname>?sslmode=require
DATABASE_URL=postgres://kasirku:changeme@localhost:5432/kasirku_sembako?sslmode=disable

# A real random secret, at least 32 characters (e.g. `openssl rand -base64 32`).
# Rotate = every issued token becomes invalid immediately.
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_TTL_DAYS=30

# Email yang otomatis dapat role admin saat register. Biarkan kosong jika tidak
# ingin auto-promote. Admin bisa manage users/subscriptions via /api/admin/*.
ADMIN_EMAIL=admin@example.com

# Comma-separated CIDRs of reverse proxies allowed to set X-Forwarded-For.
# Leave empty until this is deployed behind a real reverse proxy (Caddy/
# nginx) - otherwise rate limiting collapses every real client behind an
# unconfigured proxy into a single shared bucket. Once deployed, set this to
# the proxy's own address, e.g. TRUSTED_PROXIES=127.0.0.1/32
TRUSTED_PROXIES=

# From Play Console: Setup > App integrity / the app's package name.
GOOGLE_PLAY_PACKAGE_NAME=com.example.kasirku_sembako
# Path to the service account JSON key granted "Manage orders and
# subscriptions" access in Play Console > Setup > API access.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Max JSON backup payload size accepted per upload.
BACKUP_MAX_SIZE_MB=50
BACKUP_RETENTION_COUNT=3

SUBSCRIPTION_STALENESS_HOURS=24
